# Godot engine binaries (portable, not part of the project)
Godot_v*.exe
Godot_v*.exe.zip
*.zip

# Godot generated/cache files
godot/.godot/

# Android gradle build artifacts and large prebuilt libs
# (libs/ AARs are regenerated in CI from android_source.zip; gradle outputs are local-only)
godot/android/build/libs/
godot/android/build/build/
godot/android/build/.gradle/
godot/android/build/.gradletasks/
godot/android/build/.cxx/
godot/android/build/assets/

# Build artifacts (root-level only — godot/android/build/ is the gradle template, NOT this)
/build/
*.apk

# Secrets (keystores, passwords) - upload to GitHub Secrets instead
secrets/
*.keystore
*.jks
